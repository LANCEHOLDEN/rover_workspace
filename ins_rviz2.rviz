Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /GPS Current Position1
        - /GPS Path1
        - /TF1
        - /TF1/Status1
        - /TF1/Frames1
        - /Odometry1
        - /Odometry2
        - /Odometry3
        - /Odometry3/Shape1
        - /Odometry3/Covariance1
        - /Odometry4
        - /Odometry4/Shape1
      Splitter Ratio: 0.5
    Tree Height: 467
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
